[Unit]
Description=Binance Futures Data Sync Service (Docker)
After=network-online.target docker.service
Wants=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
User=sam
Group=sam
EnvironmentFile=/etc/downloader-sync.env

Environment=COMPOSE_PROJECT_NAME=binance-sync
Environment=QUESTDB_HOST=localhost
Environment=QUESTDB_PORT=9009

ExecStart=/home/sam/.local/bin/dotenvx run -f /media/sam/1TB/.env -- /media/sam/1TB/monitoring-stack/scripts/cron-wrapper.sh binance-sync /usr/bin/docker compose --env-file /etc/downloader-sync.env --project-directory ${BINANCE_REPO_ROOT} -f ${BINANCE_REPO_ROOT}/docker-compose.yml run --rm binance-sync

TimeoutStartSec=7200
Restart=no
StandardOutput=journal
StandardError=journal
SyslogIdentifier=binance-sync-docker

[Install]
WantedBy=multi-user.target
